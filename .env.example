# =============================================================
# AI-Powered Supply Chain Risk Intelligence Assistant — .env
# Copy this file to `.env` and fill in real values.
# =============================================================

# ---------- LLM Providers ----------
# OpenAI (gpt-4o-mini) — primary heavy-reasoning model
OPENAI_API_KEY=sk-REPLACE_ME
OPENAI_MODEL=gpt-4o-mini

# Groq (free) — llama 3.1 8B (router) + llama 3.3 70B (mid)
GROQ_API_KEY=gsk_REPLACE_ME
GROQ_MODEL_SMALL=llama-3.1-8b-instant
GROQ_MODEL_LARGE=llama-3.3-70b-versatile

# Fallback chain order (comma-separated logical names)
LLM_FALLBACK_CHAIN=openai_mini,groq_large,groq_small

# ---------- Embeddings & Reranker (local, free) ----------
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Optional — only if HF rate-limits model downloads
HUGGINGFACE_TOKEN=

# ---------- Vector Store ----------
CHROMA_PERSIST_DIR=./storage/chroma
CHROMA_COLLECTION=supply_chain_incidents

# ---------- Hybrid Retrieval ----------
DENSE_TOP_K=20
SPARSE_TOP_K=20
RRF_K=60
RERANK_TOP_K=5
CRAG_RELEVANCE_THRESHOLD=0.6

# ---------- Semantic Cache ----------
SEMANTIC_CACHE_THRESHOLD=0.92
SEMANTIC_CACHE_MAX_ITEMS=500
KEYWORD_CACHE_MAX_ITEMS=1000

# ---------- LangSmith Tracing ----------
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=lsv2_REPLACE_ME
LANGCHAIN_PROJECT=supply-chain-risk-assistant

# ---------- Kaggle MCP ----------
KAGGLE_USERNAME=REPLACE_ME
KAGGLE_KEY=REPLACE_ME
KAGGLE_MCP_URL=https://www.kaggle.com/mcp
DATACO_DATASET=shashwatwork/dataco-smart-supply-chain-for-big-data-analysis
FASHION_DATASET=harshsingh2209/supply-chain-analysis

# ---------- Ingestion ----------
DATACO_SAMPLE_ROWS=2500
INCIDENT_DOC_BATCH_SIZE=128
LOCAL_DATACO_CSV=./data/source_dataset/DataCo SMART SUPPLY CHAIN FOR BIG DATA ANALYSIS/DataCoSupplyChainDataset.csv
LOCAL_FASHION_CSV=./data/source_dataset/supply_chain_data.csv

# ---------- Persistence ----------
SQLITE_PATH=./storage/sqlite/app.db
LANGGRAPH_CHECKPOINT_DB=./storage/sqlite/checkpoints.db

# ---------- Guardrails ----------
MAX_CONTEXT_TOKENS=6000
LLMLINGUA_COMPRESSION_RATIO=0.5
INJECTION_DETECTION_ENABLED=true
PRIVACY_FILTER_ENABLED=true

# ---------- HILT ----------
HIGH_SEVERITY_INTERRUPT=true

# ---------- API server ----------
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---------- Frontend ----------
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000

# ---------- Logging ----------
LOG_LEVEL=INFO
