# =============================================================
# .claudeignore — files Claude should never read or scan
# =============================================================

# Secrets & credentials
.env
.env.*
*.pem
*.key
*.p12
*.pfx
secrets/

# Runtime data — large binary/generated files
storage/
data/source_dataset/
data/kaggle_cache/
*.db
*.sqlite
*.sqlite3

# Vector store binaries
storage/chroma/
**/*.bin
**/*.pickle
**/*.pkl

# Python artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
*.egg-info/
dist/
build/
.eggs/

# Node artifacts
node_modules/
frontend/dist/
frontend/.vite/
*.tsbuildinfo

# Logs
*.log
logs/

# OS / editor junk
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Large data files
*.csv
*.parquet
*.xlsx
*.jsonl

# Lock files (auto-generated, not useful to read)
package-lock.json
yarn.lock
poetry.lock
pip.lock
